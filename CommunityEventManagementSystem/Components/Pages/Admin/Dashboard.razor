

@page "/dashboard"

@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IEventService EventService

<PageTitle>Dashboard</PageTitle>

<div class="card border-0 shadow-lg mb-4">

    <div class="card-body text-white p-5"
         style="background:linear-gradient(135deg,#2563eb,#1e3a8a); border-radius:15px;">

        <h1 class="display-5 fw-bold">
            Community Event Management Dashboard
        </h1>

        <p class="lead mb-0">
            Executive overview of events, registrations,
            occupancy and community engagement.
        </p>

    </div>

</div> 

<div class="card border-0 shadow mt-4">

    <div class="card-body">

        <h5 class="text-success">
            ● System Operational
        </h5>

        <p class="mb-0">
            All dashboard services are functioning normally.
        </p>

    </div>

</div> 

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

          

            <p class="text-muted">
                Executive overview of events, registrations and system activity.
            </p>

        </div>

        <button class="btn btn-outline-primary"
                @onclick="RefreshDashboard">

            Refresh Dashboard

        </button>

    </div>

    @if (Events == null)
    {
        <div class="text-center p-5">

            <div class="spinner-border text-primary">
            </div>

            <h5 class="mt-3">
                Loading dashboard statistics...
            </h5>

            <p class="text-muted">
                Please wait while analytics are prepared.
            </p>

        </div>
    }
    else
    {
        <div class="alert alert-info shadow-sm">

            <strong>System Summary:</strong>

            Currently managing

            <strong>@TotalEvents</strong>

            events with

            <strong>@TotalRegistrations</strong>

            registrations and

            <strong>@RemainingSeats</strong>

            available seats.

        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">

                <div class="card stat-card h-100">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Total Events
                        </h6>

                        <h1 class="text-primary fw-bold">
                            @TotalEvents
                        </h1>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card stat-card h-100">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Upcoming Events
                        </h6>

                        <h1 class="text-success fw-bold">
                            @UpcomingEvents
                        </h1>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card stat-card h-100">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Registrations
                        </h6>

                        <h1 class="text-danger fw-bold">
                            @TotalRegistrations
                        </h1>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card stat-card h-100">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Occupancy
                        </h6>

                        <h1 class="text-warning fw-bold">
                            @($"{OverallOccupancy:F0}%")
                        </h1>

                    </div>

                </div>

            </div>

        </div>

        <div class="row mt-4">

            <div class="col-lg-8">

                <div class="card shadow border-0">

                    <div class="card-header bg-success text-white">

                        Top Performing Event

                    </div>

                    <div class="card-body">

                        @if (TopEvent is not null)
                        {
                            <h3 class="fw-bold">
                                @TopEvent.Name
                            </h3>

                            <div class="row mt-3">

                                <div class="col-md-4">

                                    <strong>Registrations</strong>

                                    <h4>
                                        @TopEvent.RegistrationCount
                                    </h4>

                                </div>

                                <div class="col-md-4">

                                    <strong>Capacity</strong>

                                    <h4>
                                        @TopEvent.MaximumParticipants
                                    </h4>

                                </div>

                                <div class="col-md-4">

                                    <strong>Occupancy</strong>

                                    <h4>
                                        @($"{TopEvent.OccupancyPercentage:F0}%")
                                    </h4>

                                </div>

                            </div>
                        }

                    </div>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="card shadow border-0">

                    <div class="card-header bg-primary text-white">

                        Dashboard Insights

                    </div>

                    <div class="card-body">

                        <p>
                            <strong>Full Events:</strong>
                            @FullEvents
                        </p>

                        <p>
                            <strong>Open Events:</strong>
                            @OpenEvents
                        </p>

                        <p>
                            <strong>Available Seats:</strong>
                            @RemainingSeats
                        </p>

                        <p>
                            <strong>Total Capacity:</strong>
                            @TotalCapacity
                        </p>

                    </div>

                </div>

            </div>

        </div>

        <div class="card shadow border-0 mt-4">

            <div class="card-header bg-dark text-white">

                Quick Actions

            </div>

            <div class="card-body">

                <a href="/events/create"
                   class="btn btn-success me-2">
                    Create Event
                </a>

                <a href="/participants/create"
                   class="btn btn-primary me-2">
                    Add Participant
                </a>

                <a href="/registrations/register"
                   class="btn btn-warning">
                    Register Participant
                </a>

            </div>

        </div>

        <div class="card shadow border-0 mt-4">

            <div class="card-header bg-info text-white">

                Upcoming Events

            </div>

            <div class="card-body">

                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Event</th>
                            <th>Date</th>
                            <th>Capacity</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var e in UpcomingEventList)
                        {
                            <tr>

                                <td>@e.Name</td>

                                <td>
                                    @e.EventDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @e.MaximumParticipants
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="card shadow border-0 mt-4">

            <div class="card-header bg-dark text-white">

                Event Performance Overview

            </div>

            <div class="card-body">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Event</th>
                            <th>Date</th>
                            <th>Capacity</th>
                            <th>Registered</th>
                            <th>Remaining</th>
                            <th>Occupancy</th>
                            <th>Status</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var e in Events.OrderBy(x => x.EventDate))
                        {
                            <tr>

                                <td class="fw-bold">
                                    @e.Name
                                </td>

                                <td>
                                    @e.EventDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @e.MaximumParticipants
                                </td>

                                <td>
                                    @e.RegistrationCount
                                </td>

                                <td>
                                    @e.RemainingSeats
                                </td>

                                <td style="width:220px">

                                    <div class="progress">

                                        <div class="progress-bar"
                                             role="progressbar"
                                             style="width:@($"{e.OccupancyPercentage}%")">

                                            @($"{e.OccupancyPercentage:F0}%")

                                        </div>

                                    </div>

                                </td>

                                <td>

                                    <span class="badge @(e.IsFull ? "bg-danger" : "bg-success")">

                                        @(e.IsFull ? "Full" : "Open")

                                    </span>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="text-center text-muted mt-4">

            Dashboard generated on
            @DateTime.Now.ToString("dd MMM yyyy HH:mm")

        </div>
    }

</div>
<div class="row mt-4">

    <div class="col-md-4">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">
                    Most Popular Event
                </h6>

                <h5 class="text-danger">
                    @mostPopularEvent
                </h5>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">
                    Average Occupancy
                </h6>

                <h2 class="text-primary">
                    @($"{averageOccupancy:F0}%")
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card shadow border-0">

            <div class="card-body text-center">

                <h6 class="text-muted">
                    Available Capacity
                </h6>

                <h2 class="text-success">
                    @availableCapacity
                </h2>

            </div>

        </div>

    </div>

</div>

@code {
    private string mostPopularEvent = "N/A";

    private double averageOccupancy;

    private int availableCapacity;

    private IEnumerable<EventDetailsDto>? Events;

    private int TotalEvents;
    private int UpcomingEvents;
    private int TotalCapacity;
    private int TotalRegistrations;
    private int FullEvents;
    private int OpenEvents;
    private int RemainingSeats;

    private double OverallOccupancy;

    private EventDetailsDto? TopEvent;

    private IEnumerable<EventDetailsDto>
        UpcomingEventList =
            Enumerable.Empty<EventDetailsDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();

    }

    private async Task RefreshDashboard()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        Events =
            await EventService.GetAllEventsAsync();

        if (Events is null)
            return;

        TotalEvents =
            Events.Count();

        UpcomingEvents =
            Events.Count(e => e.IsUpcoming);

        TotalCapacity =
            Events.Sum(e => e.MaximumParticipants);

        TotalRegistrations =
            Events.Sum(e => e.RegistrationCount);

        FullEvents =
            Events.Count(e => e.IsFull);

        OpenEvents =
            Events.Count(e => !e.IsFull);

        RemainingSeats =
            Events.Sum(e => e.RemainingSeats);

        OverallOccupancy =
            TotalCapacity == 0
                ? 0
                : (double)TotalRegistrations /
                  TotalCapacity * 100;

        TopEvent =
            Events.OrderByDescending(
                e => e.RegistrationCount)
            .FirstOrDefault();

        UpcomingEventList =
            Events.Where(e => e.IsUpcoming)
                  .OrderBy(e => e.EventDate)
                  .Take(5);

        mostPopularEvent =
TopEvent?.Name ?? "N/A";

        averageOccupancy =
            OverallOccupancy;

        availableCapacity =
            RemainingSeats;
    }

}