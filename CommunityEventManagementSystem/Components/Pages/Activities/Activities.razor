@page "/activities"

@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IActivityService ActivityService

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title mb-1">Activity Management</h1>
            <p class="section-subtitle mb-0">
                Manage workshops, talks, games, and other event activities.
            </p>
        </div>
        <a href="/activities/create" class="btn btn-primary btn-lg">
            + Create Activity
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-body">
            @if (activities == null)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 text-muted">Loading activities...</p>
                </div>
            }
            else if (!activities.Any())
            {
                <div class="text-center p-5">
                    <h5 class="fw-semibold">No activities yet</h5>
                    <p class="text-muted">Create activities to assign them to events.</p>
                    <a href="/activities/create" class="btn btn-primary">Create Activity</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in activities)
                            {
                                <tr>
                                    <td class="fw-semibold">@activity.Name</td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @activity.ActivityTypeDisplay
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => DeleteActivity(activity.Id)">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<ActivityDetailsDto>? activities;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadActivitiesAsync();
    }

    private async Task LoadActivitiesAsync()
    {
        activities = await ActivityService.GetAllActivitiesAsync();
    }

    private async Task DeleteActivity(int id)
    {
        try
        {
            await ActivityService.DeleteActivityAsync(id);
            message = "Activity deleted.";
            await LoadActivitiesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }
}
