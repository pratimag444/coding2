@page "/events"

@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IEventService EventService
@inject IVenueService VenueService
@inject IActivityService ActivityService
@implements IDisposable

<div class="container-fluid py-4 event-list-page">

    @* Toast notifications *@
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
        @if (showToast)
        {
            <div class="toast show border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header @ToastHeaderClass text-white border-0">
                    <strong class="me-auto">@ToastTitle</strong>
                    <small class="text-white-50">Just now</small>
                    <button type="button"
                            class="btn-close btn-close-white"
                            aria-label="Close"
                            @onclick="DismissToast">
                    </button>
                </div>
                <div class="toast-body">
                    @toastMessage
                </div>
            </div>
        }
    </div>

    @* Page header *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="page-title mb-1">Event Management</h1>
            <p class="section-subtitle mb-0">
                Manage community events, capacity, and registrations.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-outline-secondary"
                    @onclick="RefreshEventsAsync"
                    disabled="@isLoading">
                @if (isRefreshing)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Refreshing...</span>
                }
                else
                {
                    <span aria-hidden="true">&#8635;</span>
                    <span> Refresh</span>
                }
            </button>

            <a href="/events/create" class="btn btn-primary btn-lg">
                + Create Event
            </a>
        </div>
    </div>

    @* Load error *@
    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center shadow-sm" role="alert">
            <span class="me-2 fs-5" aria-hidden="true">&#9888;</span>
            <div class="flex-grow-1">
                <strong>Unable to load events.</strong>
                <span class="ms-1">@loadError</span>
            </div>
            <button type="button"
                    class="btn btn-sm btn-outline-danger ms-3"
                    @onclick="RefreshEventsAsync"
                    disabled="@isLoading">
                Retry
            </button>
            <button type="button"
                    class="btn-close"
                    aria-label="Dismiss"
                    @onclick="() => loadError = null">
            </button>
        </div>
    }

    @* Summary stats *@
    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow border-0 h-100">
                <div class="card-body text-center py-4">
                    <div class="text-primary fs-4 mb-2" aria-hidden="true">&#128197;</div>
                    <h6 class="text-muted text-uppercase small fw-semibold mb-2">Total Events</h6>
                    @if (isLoading)
                    {
                        <div class="placeholder-glow">
                            <span class="placeholder col-4 rounded" style="height: 2.5rem;"></span>
                        </div>
                    }
                    else
                    {
                        <h1 class="text-primary fw-bold mb-0">@TotalEvents</h1>
                    }
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow border-0 h-100">
                <div class="card-body text-center py-4">
                    <div class="text-success fs-4 mb-2" aria-hidden="true">&#9201;</div>
                    <h6 class="text-muted text-uppercase small fw-semibold mb-2">Upcoming Events</h6>
                    @if (isLoading)
                    {
                        <div class="placeholder-glow">
                            <span class="placeholder col-4 rounded" style="height: 2.5rem;"></span>
                        </div>
                    }
                    else
                    {
                        <h1 class="text-success fw-bold mb-0">@UpcomingEvents</h1>
                    }
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow border-0 h-100">
                <div class="card-body text-center py-4">
                    <div class="text-danger fs-4 mb-2" aria-hidden="true">&#128683;</div>
                    <h6 class="text-muted text-uppercase small fw-semibold mb-2">Full Events</h6>
                    @if (isLoading)
                    {
                        <div class="placeholder-glow">
                            <span class="placeholder col-4 rounded" style="height: 2.5rem;"></span>
                        </div>
                    }
                    else
                    {
                        <h1 class="text-danger fw-bold mb-0">@FullEvents</h1>
                    }
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card shadow border-0 h-100">
                <div class="card-body text-center py-4">
                    <div class="text-warning fs-4 mb-2" aria-hidden="true">&#128101;</div>
                    <h6 class="text-muted text-uppercase small fw-semibold mb-2">Total Capacity</h6>
                    @if (isLoading)
                    {
                        <div class="placeholder-glow">
                            <span class="placeholder col-4 rounded" style="height: 2.5rem;"></span>
                        </div>
                    }
                    else
                    {
                        <h1 class="text-warning fw-bold mb-0">@TotalCapacity</h1>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Search & filters *@
    <div class="card shadow border-0 mb-4">
        <div class="card-body">
            <label class="form-label fw-semibold" for="eventSearch">
                Search events
            </label>
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-white border-end-0">
                    <span aria-hidden="true">&#128269;</span>
                </span>
                <input id="eventSearch"
                       class="form-control border-start-0 @SearchInputClass"
                       placeholder="Search by event name..."
                       @bind="searchText"
                       @bind:event="oninput"
                       @bind:after="ApplyFiltersAsync"
                       aria-describedby="searchHelp" />
                @if (!string.IsNullOrWhiteSpace(searchText))
                {
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="ClearSearch"
                            aria-label="Clear search">
                        Clear
                    </button>
                }
            </div>
            <div id="searchHelp" class="form-text mt-2 mb-3">
                @if (isLoading)
                {
                    <span>Loading events...</span>
                }
                else
                {
                    <span>Showing @FilteredEvents.Count() of @TotalEvents events</span>
                }
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Filter by date</label>
                    <InputDate class="form-control"
                               @bind-Value="filterDate"
                               @bind-Value:after="ApplyFiltersAsync" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Filter by venue</label>
                    <select class="form-select"
                            @bind="selectedVenueId"
                            @bind:after="ApplyFiltersAsync">
                        <option value="0">All venues</option>
                        @foreach (var venue in venues)
                        {
                            <option value="@venue.Id">@venue.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Filter by activity</label>
                    <select class="form-select"
                            @bind="selectedActivityId"
                            @bind:after="ApplyFiltersAsync">
                        <option value="0">All activities</option>
                        @foreach (var activity in activities)
                        {
                            <option value="@activity.Id">@activity.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               id="upcomingOnly"
                               @bind="upcomingOnly"
                               @bind:after="ApplyFiltersAsync" />
                        <label class="form-check-label" for="upcomingOnly">
                            Upcoming events only
                        </label>
                    </div>
                </div>
            </div>

            @if (HasActiveFilters)
            {
                <button class="btn btn-sm btn-outline-secondary mt-3"
                        @onclick="ClearFiltersAsync">
                    Clear all filters
                </button>
            }
        </div>
    </div>

    @* Events table *@
    <div class="card shadow border-0">
        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">All Events</h5>
                @if (!isLoading && events is not null)
                {
                    <span class="badge bg-light text-dark border">
                        @FilteredEvents.Count() @(FilteredEvents.Count() == 1 ? "event" : "events")
                    </span>
                }
            </div>
        </div>

        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading events...</span>
                    </div>
                    <p class="mt-3 mb-0 text-muted fw-medium">Loading events...</p>
                </div>
            }
            else if (loadError is not null && events is null)
            {
                <div class="text-center p-5">
                    <div class="display-6 text-danger mb-3" aria-hidden="true">&#9888;</div>
                    <h5 class="fw-semibold">Something went wrong</h5>
                    <p class="text-muted mb-4">We could not retrieve the event list right now.</p>
                    <button class="btn btn-primary" @onclick="RefreshEventsAsync">
                        Try Again
                    </button>
                </div>
            }
            else if (TotalEvents == 0)
            {
                <div class="text-center p-5">
                    <div class="display-6 text-muted mb-3" aria-hidden="true">&#128197;</div>
                    <h5 class="fw-semibold">No events yet</h5>
                    <p class="text-muted mb-4">
                        Get started by creating your first community event.
                    </p>
                    <a href="/events/create" class="btn btn-primary btn-lg">
                        + Create Your First Event
                    </a>
                </div>
            }
            else if (!FilteredEvents.Any())
            {
                <div class="text-center p-5">
                    <div class="display-6 text-muted mb-3" aria-hidden="true">&#128269;</div>
                    <h5 class="fw-semibold">No matching events</h5>
                    <p class="text-muted mb-4">
                        No events match <strong>"@searchText"</strong>. Try a different search term.
                    </p>
                    <button class="btn btn-outline-primary" @onclick="ClearSearch">
                        Clear Search
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Date</th>
                                <th scope="col">Time</th>
                                <th scope="col">Capacity</th>
                                <th scope="col">Registered</th>
                                <th scope="col">Remaining</th>
                                <th scope="col">Occupancy</th>
                                <th scope="col">Venues</th>
                                <th scope="col">Activities</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in FilteredEvents)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        <a href="/events/details/@e.Id" class="text-decoration-none">
                                            @e.Name
                                        </a>
                                        @if (e.IsToday)
                                        {
                                            <span class="badge bg-info text-dark ms-1">Today</span>
                                        }
                                    </td>
                                    <td>@e.EventDateDisplay</td>
                                    <td>@e.EventTimeDisplay</td>
                                    <td>@e.MaximumParticipants</td>
                                    <td>@e.RegistrationCount</td>
                                    <td>
                                        <span class="@(e.RemainingSeats <= 5 && e.RemainingSeats > 0 ? "text-warning fw-semibold" : "")">
                                            @e.RemainingSeats
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 8px;">
                                                <div class="progress-bar bg-@e.OccupancyColor"
                                                     role="progressbar"
                                                     style="width: @(Math.Min(e.OccupancyPercentage, 100))%"
                                                     aria-valuenow="@e.OccupancyPercentage"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                            <small class="text-muted fw-semibold" style="min-width: 36px;">
                                                @e.OccupancyDisplay
                                            </small>
                                        </div>
                                    </td>
                                    <td>
                                        <small>@e.VenuesDisplay</small>
                                    </td>
                                    <td>
                                        <small>@e.ActivitiesDisplay</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-@e.StatusBadgeColor">
                                            @e.Status
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group" aria-label="Actions for @e.Name">
                                            <a href="/events/details/@e.Id"
                                               class="btn btn-outline-info"
                                               title="View details">
                                                Details
                                            </a>
                                            <a href="/events/edit/@e.Id"
                                               class="btn btn-outline-warning"
                                               title="Edit event">
                                                Edit
                                            </a>
                                            <button type="button"
                                                    class="btn btn-outline-danger"
                                                    title="Delete event"
                                                    disabled="@isDeleting"
                                                    @onclick="() => ShowDeleteConfirmation(e)">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@* Delete confirmation modal *@
@if (showDeleteModal && selectedEvent is not null)
{
    <div class="modal fade show d-block"
         tabindex="-1"
         role="dialog"
         aria-modal="true"
         aria-labelledby="deleteModalTitle"
         style="background-color: rgba(15, 23, 42, 0.55);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title" id="deleteModalTitle">
                        Confirm Deletion
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            aria-label="Close"
                            disabled="@isDeleting"
                            @onclick="CancelDelete">
                    </button>
                </div>

                <div class="modal-body">
                    <p class="mb-3">
                        Are you sure you want to permanently delete this event?
                    </p>

                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body py-3">
                            <h6 class="fw-bold mb-2">@selectedEvent.Name</h6>
                            <div class="small text-muted">
                                <div>@selectedEvent.EventDateDisplay at @selectedEvent.EventTimeDisplay</div>
                                <div>@selectedEvent.CapacitySummary registered</div>
                            </div>
                        </div>
                    </div>

                    @if (selectedEvent.RegistrationCount > 0)
                    {
                        <div class="alert alert-warning d-flex align-items-start mb-3" role="alert">
                            <span class="me-2" aria-hidden="true">&#9888;</span>
                            <div>
                                This event has <strong>@selectedEvent.RegistrationCount</strong>
                                active registration@(selectedEvent.RegistrationCount == 1 ? "" : "s").
                                Deleting it will remove all associated registration data.
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(deleteError))
                    {
                        <div class="alert alert-danger mb-0" role="alert">
                            @deleteError
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">
                            This action cannot be undone.
                        </p>
                    }
                </div>

                <div class="modal-footer border-0">
                    <button type="button"
                            class="btn btn-secondary"
                            disabled="@isDeleting"
                            @onclick="CancelDelete">
                        Cancel
                    </button>
                    <button type="button"
                            class="btn btn-danger"
                            disabled="@isDeleting"
                            @onclick="ConfirmDeleteAsync">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <span>Delete Event</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .event-list-page .toast.show {
        opacity: 1;
    }

    .event-list-page .input-group-text,
    .event-list-page .form-control.border-start-0:focus {
        box-shadow: none;
    }

    .event-list-page .table tbody tr {
        transition: background-color 0.15s ease;
    }
</style>

@code {
    private IEnumerable<EventDetailsDto>? events;
    private IEnumerable<EventDetailsDto> filteredEvents = Enumerable.Empty<EventDetailsDto>();
    private IEnumerable<VenueDetailsDto> venues = Enumerable.Empty<VenueDetailsDto>();
    private IEnumerable<ActivityDetailsDto> activities = Enumerable.Empty<ActivityDetailsDto>();

    private string searchText = string.Empty;
    private DateOnly? filterDate;
    private int selectedVenueId;
    private int selectedActivityId;
    private bool upcomingOnly;
    private string? loadError;
    private string? deleteError;

    private bool isLoading = true;
    private bool isRefreshing;
    private bool isDeleting;
    private bool showDeleteModal;
    private EventDetailsDto? selectedEvent;

    private bool showToast;
    private string toastMessage = string.Empty;
    private string toastType = "success";
    private CancellationTokenSource? toastCts;

    private bool HasSearchText =>
        !string.IsNullOrWhiteSpace(searchText);

    private string SearchInputClass =>
        HasSearchText && !FilteredEvents.Any() && !isLoading && TotalEvents > 0
            ? "is-invalid"
            : HasSearchText && FilteredEvents.Any()
                ? "is-valid"
                : string.Empty;

    private string ToastHeaderClass =>
        toastType switch
        {
            "danger" => "bg-danger",
            "warning" => "bg-warning text-dark",
            "info" => "bg-info text-dark",
            _ => "bg-success"
        };

    private string ToastTitle =>
        toastType switch
        {
            "danger" => "Error",
            "warning" => "Warning",
            "info" => "Information",
            _ => "Success"
        };

    private int TotalEvents =>
        events?.Count() ?? 0;

    private int UpcomingEvents =>
        events?.Count(e => e.IsUpcoming) ?? 0;

    private int FullEvents =>
        events?.Count(e => e.IsFull) ?? 0;

    private int TotalCapacity =>
        events?.Sum(e => e.MaximumParticipants) ?? 0;

    private bool HasActiveFilters =>
        filterDate.HasValue
        || selectedVenueId > 0
        || selectedActivityId > 0
        || upcomingOnly
        || HasSearchText;

    private IEnumerable<EventDetailsDto> FilteredEvents =>
        filteredEvents;

    protected override async Task OnInitializedAsync()
    {
        venues = await VenueService.GetAllVenuesAsync();
        activities = await ActivityService.GetAllActivitiesAsync();
        await LoadEventsAsync(isInitialLoad: true);
    }

    private async Task ApplyFiltersAsync()
    {
        if (events is null)
        {
            return;
        }

        filteredEvents = await EventService.FilterEventsAsync(
            filterDate,
            selectedVenueId > 0 ? selectedVenueId : null,
            selectedActivityId > 0 ? selectedActivityId : null,
            searchText,
            upcomingOnly);
    }

    private async Task LoadEventsAsync(bool isInitialLoad = false)
    {
        if (isInitialLoad)
        {
            isLoading = true;
        }
        else
        {
            isRefreshing = true;
        }

        loadError = null;

        try
        {
            events = await EventService.GetAllEventsAsync();
            await ApplyFiltersAsync();
        }
        catch (Exception)
        {
            loadError = "Please check your connection and try again.";
            if (isInitialLoad)
            {
                events = null;
            }
        }
        finally
        {
            isLoading = false;
            isRefreshing = false;
        }
    }

    private async Task RefreshEventsAsync()
    {
        await LoadEventsAsync();
        if (loadError is null)
        {
            await ShowToastAsync("Event list refreshed.", "info");
        }
    }

    private async Task ClearSearch()
    {
        searchText = string.Empty;
        await ApplyFiltersAsync();
    }

    private async Task ClearFiltersAsync()
    {
        searchText = string.Empty;
        filterDate = null;
        selectedVenueId = 0;
        selectedActivityId = 0;
        upcomingOnly = false;
        await ApplyFiltersAsync();
    }

    private void ShowDeleteConfirmation(EventDetailsDto eventItem)
    {
        selectedEvent = eventItem;
        deleteError = null;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        if (isDeleting)
        {
            return;
        }

        showDeleteModal = false;
        selectedEvent = null;
        deleteError = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (selectedEvent is null || isDeleting)
        {
            return;
        }

        isDeleting = true;
        deleteError = null;

        var deletedName = selectedEvent.Name;

        try
        {
            await EventService.DeleteEventAsync(selectedEvent.Id);
            await LoadEventsAsync();

            showDeleteModal = false;
            selectedEvent = null;

            await ShowToastAsync($"Event \"{deletedName}\" has been successfully deleted.", "success");
        }
        catch (Exception)
        {
            deleteError = "Unable to delete this event. It may have been removed or is temporarily unavailable.";
            await ShowToastAsync("Failed to delete the event. Please try again.", "danger");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private async Task ShowToastAsync(string message, string type)
    {
        toastCts?.Cancel();
        toastCts?.Dispose();
        toastCts = new CancellationTokenSource();

        toastMessage = message;
        toastType = type;
        showToast = true;

        try
        {
            await Task.Delay(5000, toastCts.Token);
            showToast = false;
        }
        catch (TaskCanceledException)
        {
            // Toast dismissed or replaced before auto-hide.
        }

        await InvokeAsync(StateHasChanged);
    }

    private void DismissToast()
    {
        toastCts?.Cancel();
        showToast = false;
    }

    public void Dispose()
    {
        toastCts?.Cancel();
        toastCts?.Dispose();
    }
}
