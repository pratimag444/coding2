@page "/"

<div class="hero-section">

    <div class="hero-content">

        <h1>
            Community Event Management System
        </h1>

        <p class="lead">
            A modern platform for managing community events,
            participant registrations and event capacity.
        </p>

        <div class="hero-buttons mt-4">

            <a class="btn btn-primary btn-lg me-2"
               href="/events">
                View Events
            </a>

            <a class="btn btn-success btn-lg me-2"
               href="/events/create">
                Create Event
            </a>

            <a class="btn btn-warning btn-lg"
               href="/registrations/register">
                Register Participant
            </a>

        </div>

    </div>

</div>

<div class="container mt-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            System Features
        </h2>

        <p class="text-muted">
            Everything required to manage events efficiently.
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-3">

            <div class="card shadow border-0 h-100">

                <div class="card-body text-center">

                    <h1>
                        📅
                    </h1>

                    <h5 class="fw-bold">
                        Event Management
                    </h5>

                    <p class="text-muted">
                        Create, manage and monitor events.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow border-0 h-100">

                <div class="card-body text-center">

                    <h1>
                        👥
                    </h1>

                    <h5 class="fw-bold">
                        Participants
                    </h5>

                    <p class="text-muted">
                        Manage participant records and activity.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow border-0 h-100">

                <div class="card-body text-center">

                    <h1>
                        📝
                    </h1>

                    <h5 class="fw-bold">
                        Registrations
                    </h5>

                    <p class="text-muted">
                        Track event registrations in real time.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow border-0 h-100">

                <div class="card-body text-center">

                    <h1>
                        📊
                    </h1>

                    <h5 class="fw-bold">
                        Analytics
                    </h5>

                    <p class="text-muted">
                        View event performance and occupancy.
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow border-0 mt-5">

        <div class="card-header bg-primary text-white">

            <h4 class="mb-0">
                Quick Access
            </h4>

        </div>

        <div class="card-body text-center">

            <a href="/events"
               class="btn btn-outline-primary btn-lg m-2">

                Event List

            </a>

            <a href="/participants"
               class="btn btn-outline-success btn-lg m-2">

                Participants

            </a>

            <a href="/registrations"
               class="btn btn-outline-warning btn-lg m-2">

                Registrations

            </a>

            <a href="/dashboard"
               class="btn btn-outline-dark btn-lg m-2">

                Dashboard

            </a>

        </div>

    </div>

    <div class="card shadow border-0 mt-5">

        <div class="card-body text-center p-5">

            <h3 class="fw-bold">
                Community Event Management Solution
            </h3>

            <p class="text-muted mt-3">

                This system provides a complete solution for
                managing events, participants and registrations
                through a secure and user-friendly interface.

            </p>

        </div>

    </div>

</div>