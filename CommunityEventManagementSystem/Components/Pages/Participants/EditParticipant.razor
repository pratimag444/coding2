@page "/participants/edit/{Id:int}"

@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IParticipantService ParticipantService
@inject NavigationManager Navigation

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-warning text-dark">

            <h2 class="mb-0">
                Edit Participant
            </h2>

        </div>

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            <EditForm Model="participantDto"
                      OnValidSubmit="UpdateParticipant">

                <DataAnnotationsValidator />

                <ValidationSummary />

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label fw-bold">
                            First Name
                        </label>

                        <InputText class="form-control"
                                   @bind-Value="participantDto.FirstName" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label fw-bold">
                            Last Name
                        </label>

                        <InputText class="form-control"
                                   @bind-Value="participantDto.LastName" />

                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label fw-bold">
                        Email
                    </label>

                    <InputText class="form-control"
                               @bind-Value="participantDto.Email" />

                </div>

                <div class="mb-4">

                    <label class="form-label fw-bold">
                        Phone Number
                    </label>

                    <InputText class="form-control"
                               @bind-Value="participantDto.PhoneNumber" />

                </div>

                <button type="submit"
                        class="btn btn-success">

                    Save Changes

                </button>

                <a href="/participants"
                   class="btn btn-secondary ms-2">

                    Cancel

                </a>

            </EditForm>

        </div>

    </div>

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private UpdateParticipantDto participantDto = new();

    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var participant =
            await ParticipantService
                .GetParticipantByIdAsync(Id);

        if (participant is null)
        {
            errorMessage =
                "Participant not found.";

            return;
        }

        var names =
            participant.FullName.Split(
                ' ',
                StringSplitOptions.RemoveEmptyEntries);

        participantDto.Id =
            participant.Id;

        participantDto.FirstName =
            names.Length > 0
                ? names[0]
                : string.Empty;

        participantDto.LastName =
            names.Length > 1
                ? string.Join(
                    " ",
                    names.Skip(1))
                : string.Empty;

        participantDto.Email =
            participant.Email;

        participantDto.PhoneNumber =
            participant.PhoneNumber;
    }

    private async Task UpdateParticipant()
    {
        try
        {
            await ParticipantService
                .UpdateParticipantAsync(
                    participantDto);

            Navigation.NavigateTo(
                "/participants");
        }
        catch (Exception ex)
        {
            errorMessage =
                ex.Message;
        }
    }
}