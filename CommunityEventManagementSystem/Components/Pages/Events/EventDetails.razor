@page "/events/details/{Id:int}"

@using Microsoft.AspNetCore.Components
@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IEventService EventService
@inject NavigationManager Navigation

@if (eventItem == null)
{
    <div class="text-center mt-5">

        <div class="spinner-border text-primary">
        </div>

        <p class="mt-3">
            Loading event details...
        </p>

    </div>
}
else
{
    <div class="container-fluid">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h1 class="fw-bold">
                    @eventItem.Name
                </h1>

                <p class="text-muted">
                    Event Performance & Information
                </p>

            </div>

            <button class="btn btn-outline-secondary"
                    @onclick="BackToEvents">

                Back To Events

            </button>

        </div>

        <div class="row g-4 mb-4">

            <div class="col-md-3">

                <div class="card shadow border-0">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Capacity
                        </h6>

                        <h2 class="text-primary">
                            @eventItem.MaximumParticipants
                        </h2>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow border-0">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Registrations
                        </h6>

                        <h2 class="text-success">
                            @eventItem.RegistrationCount
                        </h2>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow border-0">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Remaining Seats
                        </h6>

                        <h2 class="text-warning">
                            @eventItem.RemainingSeats
                        </h2>

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card shadow border-0">

                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Occupancy
                        </h6>

                        <h2 class="text-danger">
                            @($"{eventItem.OccupancyPercentage:F0}%")
                        </h2>

                    </div>

                </div>

            </div>

        </div>

        <div class="card shadow border-0 mb-4">

            <div class="card-header bg-primary text-white">

                <h4 class="mb-0">
                    Event Information
                </h4>

            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6">

                        <h5 class="fw-bold">
                            Description
                        </h5>

                        <p>
                            @eventItem.Description
                        </p>

                    </div>

                    <div class="col-md-6">

                        <table class="table">

                            <tr>
                                <th>Date</th>
                                <td>
                                    @eventItem.EventDate.ToString("dd MMM yyyy")
                                </td>
                            </tr>

                            <tr>
                                <th>Time</th>
                                <td>
                                    @eventItem.EventTime
                                </td>
                            </tr>

                            <tr>
                                <th>Venues</th>
                                <td>@eventItem.VenuesDisplay</td>
                            </tr>

                            <tr>
                                <th>Activities</th>
                                <td>@eventItem.ActivitiesDisplay</td>
                            </tr>

                            <tr>
                                <th>Status</th>
                                <td>

                                    @if (eventItem.IsFull)
                                    {
                                        <span class="badge bg-danger">
                                            Full
                                        </span>
                                    }
                                    else if (eventItem.OccupancyPercentage >= 80)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Almost Full
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            Open
                                        </span>
                                    }

                                </td>
                            </tr>

                            <tr>
                                <th>Category</th>
                                <td>

                                    @if (eventItem.MaximumParticipants >= 500)
                                    {
                                        <span class="badge bg-danger">
                                            Large Event
                                        </span>
                                    }
                                    else if (eventItem.MaximumParticipants >= 100)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Medium Event
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">
                                            Small Event
                                        </span>
                                    }

                                </td>
                            </tr>

                        </table>

                    </div>

                </div>

            </div>

        </div>

        <div class="card shadow border-0">

            <div class="card-header bg-dark text-white">

                Capacity Utilisation

            </div>

            <div class="card-body">

                <div class="progress"
                     style="height:30px;">

                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="@($"width:{eventItem.OccupancyPercentage}%")">

                        @($"{eventItem.OccupancyPercentage:F0}%")

                    </div>

                </div>

                <div class="mt-3">

                    <strong>
                        @eventItem.RegistrationCount
                    </strong>

                    registrations out of

                    <strong>
                        @eventItem.MaximumParticipants
                    </strong>

                    available seats.

                </div>

            </div>

        </div>

    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private EventDetailsDto? eventItem;

    protected override async Task OnInitializedAsync()
    {
        eventItem =
            await EventService.GetEventByIdAsync(Id);
    }

    private void BackToEvents()
    {
        Navigation.NavigateTo("/events");
    }

}

