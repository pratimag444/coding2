@page "/activities/create"

@using CommunityEventManagementSystem.Domain.Enums
@using CommunityEventManagementSystem.DTOs
@using CommunityEventManagementSystem.Services.Interfaces

@inject IActivityService ActivityService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h2 class="mb-0">Create Activity</h2>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <EditForm Model="activityDto"
                              OnValidSubmit="SaveActivity"
                              FormName="CreateActivityForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Activity Name *</label>
                            <InputText class="form-control"
                                       @bind-Value="activityDto.Name" />
                            <ValidationMessage For="@(() => activityDto.Name)" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Activity Type *</label>
                            <InputSelect class="form-select"
                                         @bind-Value="activityDto.ActivityType">
                                @foreach (var type in Enum.GetValues<ActivityType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => activityDto.ActivityType)" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-success btn-lg"
                                    disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <span>Save Activity</span>
                                }
                            </button>
                            <a href="/activities" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateActivityDto activityDto = new();
    private string errorMessage = string.Empty;
    private bool isSaving;

    private async Task SaveActivity()
    {
        errorMessage = string.Empty;
        isSaving = true;

        try
        {
            await ActivityService.CreateActivityAsync(activityDto);
            Navigation.NavigateTo("/activities");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
}
